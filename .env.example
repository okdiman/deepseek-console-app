# Provider selection: "deepseek" | "groq" | "ollama"
# Set PROVIDER=ollama to run fully locally without any cloud API key
PROVIDER=deepseek

# DeepSeek API Configuration
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Local Ollama (no API key required) ────────────────────────────────────────
# Requires Ollama running: https://ollama.com — pull model: ollama pull qwen2.5:7b
# PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_MAX_TOKENS=4000
# OLLAMA_TIMEOUT_SECONDS=120

# ── Day 30: Private service settings ──────────────────────────────────────────
# Bind address for the web server (0.0.0.0 to accept connections from the network)
# SERVICE_HOST=0.0.0.0
# SERVICE_PORT=8000
#
# API key auth — set a non-empty value to require X-API-Key header on all API calls.
# Leave empty (or unset) to disable auth (local / trusted-network use).
# SERVICE_API_KEY=your-secret-key-here
#
# Rate limiting — max requests per minute per IP (default: 60)
# RATE_LIMIT_PER_MINUTE=60
#
# Max input message length in characters (0 = unlimited)
# MAX_INPUT_CHARS=4000
#
# Ollama network binding — to accept connections from other machines:
#   OLLAMA_HOST=0.0.0.0:11434  (set in shell or systemd, not in .env)
#   Then set OLLAMA_URL to point at the server's LAN IP, e.g.:
# OLLAMA_URL=http://192.168.1.100:11434

# Data directory (chat history, memory, scheduler DB, MCP configs)
# Default: ./data (relative to project root)
# DEEPSEEK_DATA_DIR=data

# ── RAG / Document Indexing ────────────────────────────────────────────────
# Requires Ollama running locally: https://ollama.com
# Pull the embedding model: ollama pull qwen3-embedding:0.6b
RAG_OLLAMA_URL=http://localhost:11434
RAG_OLLAMA_MODEL=qwen3-embedding:0.6b
RAG_EMBEDDING_DIM=1024
RAG_FIXED_CHUNK_SIZE=400
RAG_FIXED_CHUNK_OVERLAP=50
RAG_DB_PATH=experiments/rag_compare/data/doc_index.db
# Hook settings (used by RagHook in web/console agents)
RAG_ENABLED=true
RAG_TOP_K=3
RAG_SEARCH_STRATEGY=structure
# Reranking / filtering (Day 23)
RAG_PRE_RERANK_TOP_K=10         # candidates fetched before filtering (>= RAG_TOP_K)
RAG_RERANKER_TYPE=threshold     # "none" | "threshold" | "heuristic"
RAG_RERANKER_THRESHOLD=0.30     # minimum cosine similarity score to keep a chunk
RAG_QUERY_REWRITE_ENABLED=false # rewrite query via LLM before embedding
# Citations & anti-hallucination (Day 24)
RAG_CITATIONS_ENABLED=true      # inject numbered citation format + instructions
RAG_IDK_THRESHOLD=0.45          # max_score below this → "I don't know" response
RAG_WEAK_CONTEXT_THRESHOLD=0.55 # max_score below this → uncertain response with caveat
